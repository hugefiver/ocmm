// Sample ocmm config. Drop this at:
//   <project>/.opencode/ocmm.jsonc
//   ~/.config/opencode/ocmm.jsonc      (Linux/macOS)
//   %APPDATA%\opencode\ocmm.jsonc       (Windows)
{
  "disabledAgents": [],

  "agents": {
    // Shorthand: pin a single model for an agent.
    "reviewer": {
      "model": "anthropic/claude-opus-4-7"
    },

    // Full ModelRequirement form.
    "orchestrator": {
      "requirement": {
        "variant": "max",
        "requiresAnyModel": true,
        "fallbackChain": [
          { "providers": ["anthropic"], "model": "claude-opus-4-7", "variant": "max" },
          { "providers": ["openai", "github-copilot"], "model": "gpt-5.5", "variant": "high" },
          { "providers": ["zhipu"], "model": "glm-5.1" }
        ]
      }
    }
  },

  "intent": {
    "enabled": true,
    "skipAgents": ["plan"]
  },

  "fallbackModels": [
    "openai/gpt-5.4-mini",
    "anthropic/claude-haiku-4-5"
  ],

  "systemDefaultModel": "openai/gpt-5.4-mini",

  "debug": false
}
