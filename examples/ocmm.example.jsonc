// Sample ocmm config. Drop this at:
//   <project>/.opencode/ocmm.jsonc
//   ~/.config/opencode/ocmm.jsonc          (default on Linux, macOS, and Windows)
//   $XDG_CONFIG_HOME/opencode/ocmm.jsonc   (when XDG_CONFIG_HOME is set)
//
// Project config wins over user config on conflicts.
// `disabledAgents` and `fallbackModels` are unioned across both.
{
  "disabledAgents": [],

  // Preferred language/locale for primary-capable agents. Examples:
  // "zh", "zh-Hans", "zh-CN", "en-US". Omit to follow the user's language.
  // "locale": "zh-CN",

  // Fast routing is opt-in. Provider names are case-sensitive; omitted/empty
  // providers disable promotion. Mapping keys are qualified original models.
  "fastModels": {
    "providers": ["openai"],
    "mappings": {
      "openai/gpt-5.5": "gpt-5.5-fast"
    }
  },

  // Agents accept shorthand or full ModelRequirement form.
  "agents": {
    // Shorthand: pin a single model + optional variant.
    "reviewer": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },

    // A qualified alias imports only the target requirement. These behavior
    // fields remain local to oracle; `precision` is defined below.
    "oracle": {
      "alias": "precision:reviewer",
      "description": "Local Oracle review behavior",
      "tools": { "task": false },
      "permission": { "question": "allow" },
      "promptAppend": "Keep Oracle-specific review guidance local."
    },

    // Shorthand with a fallback list. Strings are parsed as "provider/model";
    // objects pass through as full FallbackEntry.
    "orchestrator": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
      "fallbackModels": [
        "openai/gpt-5.5",
        { "providers": ["zhipu"], "model": "glm-5.1" }
      ]
    },

    // Full ModelRequirement form (passthrough — no normalization).
    "worker": {
      "requirement": {
        "variant": "medium",
        "requiresProvider": ["openai"],
        "fallbackChain": [
          { "providers": ["openai"], "model": "gpt-5.5", "variant": "medium" }
        ]
      }
    },

    // Disable a built-in agent entirely.
    "media-reader": { "disabled": true }
  },

  // Canonical review slot + logical tier configuration via `variants`:
  /*
  {
    "agents": {
      "oracle": {
        "model": "openai/gpt-5.6-terra",
        "variant": "xhigh",
        "variants": {
          "low": "high",
          "high": "max",
          "max": { "model": "openai/gpt-5.6-sol", "variant": "max" }
        }
      },
      "oracle-2nd": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "xhigh",
        "variants": { "max": "max" }
      },
      "oracle-3rd": { "model": "google/gemini-3.1-pro" },
      "reviewer": {
        "model": "openai/gpt-5.6-sol",
        "variants": { "high": { "variant": "max" } }
      },
      "planner": {
        "variants": {
          "low": { "model": "openai/gpt-5.5", "variant": "high" },
          "high": "max",
          "max": { "model": "openai/gpt-5.6-sol", "variant": "max" }
        }
      },
      "plan-critic": {
        "variants": {
          "low": { "model": "openai/gpt-5.5", "variant": "low" },
          "high": "xhigh",
          "max": { "model": "openai/gpt-5.6-sol", "variant": "max" }
        }
      }
    }
  }
  */

  // Review-slot semantics:
  // - unsuffixed means logical normal;
  // - logical tier and native model variant are separate;
  // - slots are priority, not capability;
  // - slot 3-9 require explicit config;
  // - multiple configured profiles do not fan out;
  // - Reviewer has no ordinal slots;
  // - xhigh-equivalent review floors still apply to logical low;
  // - unsuffixed `planner` and `plan-critic` are logical normal;
  // - planning suffix profiles exist only for explicitly configured `variants`;
  // - current callable/registered names, not this example, prove availability;
  // - planning tiers inherit their canonical role prompt, mode, permissions, and receipt contract;
  // - `plan-critic-low` may select a cheaper model but always keeps the xhigh-equivalent floor;
  // - `agents.oracle-high` is deprecated config spelling migrated to `agents.oracle-2nd`,
  //   while runtime `oracle-high` is first-slot logical high;
  // - alias/canonical collisions fail.

  // Disable example:
  // - `oracle-2nd` disables that whole slot and all its tiers.
  // - `oracle-high` disables only first-slot logical high.
  /*
  {
    "disabledAgents": ["oracle-2nd", "oracle-high"],
    "disabledHooks": ["subagent-interruption-recovery"]
  }
  */

  // Interruption recovery behavior summary:
  // 1) reuses existing 429/generic fallback controller budgets;
  // 2) child-session keyed correlation + parent-part dedupe;
  // 3) child `session.error` counted as provider-error evidence;
  // 4) never retries explicit abort/permission denial/unknown agent/deletion/ordinary empty output;
  // 5) may append one manual-continuation notice only with explicit task id evidence;
  //    never substitutes childSessionID for task_id, dispatches from tool.execute.after,
  //    or synthesizes parent prompts.

  // Categories work the same way. Each category is also registered
  // as a mode:"subagent" entry, so callers can invoke it via
  // `task(subagent_type="hard-reasoning", ...)`.
  "categories": {
    "hard-reasoning": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallbackModels": ["anthropic/claude-opus-4-7"]
    },
    "frontend": {
      "model": "google/gemini-3.1-pro",
      "variant": "high"
    }
  },

  // Reactive runtime fallback on session.error.
  "runtimeFallback": {
    "enabled": true,            // master switch (false = event hook no-ops)
    "dispatch": true,           // false = observe-only (classify + log, no retry)
    "maxAttempts": 3,           // cap committed model switches per session
    "cooldownSeconds": 60,      // skip a failed model for this long
    "retryOnStatusCodes": [429, 500, 502, 503, 504],
    "retryOnPatterns": [
      "rate limit",
      "overloaded",
      "temporarily unavailable",
      "service unavailable",
      "internal server error",
      "gateway timeout",
      "bad gateway",
      "capacity",
      "try again"
    ],
    "subagent429": {
      "enabled": true,
      "maxRetries": 5,
      "providerScopes": {
        "anthropic": "provider",
        "openai": "model"
      }
    }
  },

  "intent": {
    "enabled": true,
    "skipAgents": ["plan"]
  },

  // Named partial overlays. At load time, the active profile is deep-merged
  // over the base config (profile wins). Select via `activeProfile` here or
  // the OCMM_PROFILE env var (env wins). Missing profile warns and preserves the base config.
  "profiles": {
    "precision": {
      // A profile `providers` array replaces the base allowlist, while
      // `mappings` deep-merges by qualified original-model key.
      "fastModels": {
        "providers": ["openai"],
        "mappings": {
          "openai/gpt-5.5": "gpt-5.5-fast"
        }
      },
      "agents": {
        // Complete requirement imported by agents.oracle's qualified alias.
        "reviewer": {
          "requirement": {
            "variant": "max",
            "requiresProvider": ["openai"],
            "fallbackChain": [
              { "providers": ["openai"], "model": "gpt-5.5", "variant": "max" },
              { "providers": ["anthropic"], "model": "claude-opus-4-7", "variant": "high" }
            ]
          }
        }
      }
    },
    "gpu": {
      "agents": {
        "orchestrator": { "model": "openai/gpt-5.5", "variant": "high" },
        "worker": { "model": "openai/gpt-5.5", "variant": "high" }
      },
      "runtimeFallback": {
        "maxAttempts": 5,
        "subagent429": { "maxRetries": 2 }
      }
    },
    "claude": {
      "agents": {
        "orchestrator": { "model": "anthropic/claude-opus-4-7", "variant": "max" },
        "reviewer": { "model": "anthropic/claude-opus-4-7", "variant": "max" }
      }
    },
    "minimal": {
      "agents": { "orchestrator": { "model": "openai/gpt-5.4-mini" } },
      "disabledAgents": ["media-reader", "plan-critic"],
      "debug": true
    }
  },

  // "activeProfile": "gpu",

  "fallbackModels": [
    "openai/gpt-5.4-mini",
    "anthropic/claude-haiku-4-5"
  ],

  "systemDefaultModel": "openai/gpt-5.4-mini",

  "registerBuiltinAgents": true,
  "debug": false
}
