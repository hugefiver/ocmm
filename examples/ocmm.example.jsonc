// Sample ocmm config. Drop this at:
//   <project>/.opencode/ocmm.jsonc
//   ~/.config/opencode/ocmm.jsonc          (Linux/macOS)
//   $XDG_CONFIG_HOME/opencode/ocmm.jsonc   (if XDG_CONFIG_HOME is set)
//   %APPDATA%\opencode\ocmm.jsonc          (Windows, when XDG_CONFIG_HOME is unset)
//
// Project config wins over user config on conflicts.
// `disabledAgents` and `fallbackModels` are unioned across both.
{
  "disabledAgents": [],

  // Agents accept shorthand or full ModelRequirement form.
  "agents": {
    // Shorthand: pin a single model + optional variant.
    "reviewer": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },

    // Shorthand with a fallback list. Strings are parsed as "provider/model";
    // objects pass through as full FallbackEntry.
    "orchestrator": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
      "fallbackModels": [
        "openai/gpt-5.5",
        { "providers": ["zhipu"], "model": "glm-5.1" }
      ]
    },

    // Full ModelRequirement form (passthrough — no normalization).
    "worker": {
      "requirement": {
        "variant": "medium",
        "requiresProvider": ["openai"],
        "fallbackChain": [
          { "providers": ["openai"], "model": "gpt-5.5", "variant": "medium" }
        ]
      }
    },

    // Disable a built-in agent entirely.
    "media-reader": { "disabled": true }
  },

  // Categories work the same way. Each category is also registered
  // as a mode:"subagent" entry, so callers can invoke it via
  // `task(subagent_type="hard-reasoning", ...)`.
  "categories": {
    "hard-reasoning": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallbackModels": ["anthropic/claude-opus-4-7"]
    },
    "frontend": {
      "model": "google/gemini-3.1-pro",
      "variant": "high"
    }
  },

  // Reactive runtime fallback on session.error.
  "runtimeFallback": {
    "enabled": true,            // master switch (false = event hook no-ops)
    "dispatch": true,           // false = observe-only (classify + log, no retry)
    "maxAttempts": 3,           // cap per session
    "cooldownSeconds": 60,      // skip a failed model for this long
    "retryOnStatusCodes": [429, 500, 502, 503, 504],
    "retryOnPatterns": [
      "rate limit",
      "overloaded",
      "temporarily unavailable",
      "service unavailable",
      "internal server error",
      "gateway timeout",
      "bad gateway",
      "capacity",
      "try again"
    ]
  },

  "intent": {
    "enabled": true,
    "skipAgents": ["plan"]
  },

  // Named partial overlays. At load time, the active profile is deep-merged
  // over the base config (profile wins). Select via `activeProfile` here or
  // the OCMM_PROFILE env var (env wins). Missing profile = silently ignored.
  "profiles": {
    "gpu": {
      "agents": {
        "orchestrator": { "model": "openai/gpt-5.5", "variant": "high" },
        "worker": { "model": "openai/gpt-5.5", "variant": "high" }
      },
      "runtimeFallback": { "maxAttempts": 5 }
    },
    "claude": {
      "agents": {
        "orchestrator": { "model": "anthropic/claude-opus-4-7", "variant": "max" },
        "reviewer": { "model": "anthropic/claude-opus-4-7", "variant": "max" }
      }
    },
    "minimal": {
      "agents": { "orchestrator": { "model": "openai/gpt-5.4-mini" } },
      "disabledAgents": ["media-reader", "plan-critic"],
      "debug": true
    }
  },

  // "activeProfile": "gpu",

  "fallbackModels": [
    "openai/gpt-5.4-mini",
    "anthropic/claude-haiku-4-5"
  ],

  "systemDefaultModel": "openai/gpt-5.4-mini",

  "registerBuiltinAgents": true,
  "debug": false
}
