{
  "name": "ocmm",
  "version": "0.6.0",
  "description": "OpenCode Multi-Model Auto-Router plugin (ocmm). Per-agent model selection, variant -> param translation, intent-keyword mode injection.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./profiles": {
      "types": "./dist/cli/profiles.d.ts",
      "import": "./dist/cli/profiles.js"
    }
  },
  "bin": {
    "ocmm": "./dist/cli/shim.js",
    "ocmm-profiles": "./dist/cli/profiles.js",
    "ocmm-lsp": "./dist/cli/ocmm-lsp.js"
  },
  "files": [
    ".agents",
    ".codex",
    "dist",
    "plugins",
    "prompts",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm run build:ts && pnpm run build:lsp",
    "build:ts": "tsc -p tsconfig.json",
    "build:lsp": "node --experimental-strip-types scripts/build-ocmm-lsp.ts",
    "build:watch": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:ts && pnpm run test:lsp",
    "test:ts": "node --test --experimental-strip-types --test-reporter=spec \"src/**/*.test.ts\"",
    "test:lsp": "cargo test -p ocmm-lsp",
    "cli": "node --experimental-strip-types src/cli/profiles.ts",
    "clean": "rimraf dist target",
    "gen-schema": "node --experimental-strip-types scripts/gen-schema.ts",
    "gen:codex-plugin": "node --experimental-strip-types scripts/gen-codex-plugin.ts",
    "sync:lsp-packages": "node --experimental-strip-types scripts/sync-lsp-packages.ts",
    "stage:lsp-packages": "node --experimental-strip-types scripts/stage-lsp-packages.ts",
    "check:release-version": "node --experimental-strip-types scripts/check-release-version.ts",
    "normalize:ocmm-package": "node --experimental-strip-types scripts/normalize-ocmm-package.ts"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "codex-plugin",
    "model-routing",
    "multi-model"
  ],
  "author": "Hugefiver",
  "license": "LicenseRef-AAAPL",
  "repository": {
    "type": "git",
    "url": "https://github.com/hugefiver/ocmm"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "ocmm-lsp-linux-x64-gnu": "workspace:*",
    "ocmm-lsp-linux-arm64-gnu": "workspace:*",
    "ocmm-lsp-linux-x64-musl": "workspace:*",
    "ocmm-lsp-linux-arm64-musl": "workspace:*",
    "ocmm-lsp-darwin-x64": "workspace:*",
    "ocmm-lsp-darwin-arm64": "workspace:*",
    "ocmm-lsp-windows-x64": "workspace:*",
    "ocmm-lsp-windows-arm64": "workspace:*"
  },
  "ocmm": {
    "lspVersion": "0.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  }
}
